nel{\r\n  background:#111827;\r\n  padding:20px;\r\n  border-radius:10px;\r\n}</style></head>\n  <body>\n    <div id=\"root\"><div class=\"layout\"><div class=\"sidebar\"><h2>Dashboard</h2><ul><li>Projects</li><li>Crawlers</li><li>Logs</li><li>Settings</li></ul></div><div class=\"main-content\"><div class=\"topbar\"><h1>Projects Dashboard</h1></div><div class=\"cards\"><div class=\"project-card\"><h3>GitHub Monitor</h3><p>Status: Running</p><button>Open</button></div><div class=\"project-card\"><h3>GitHub Monitor</h3><p>Status: Running</p><button>Open</button></div><div class=\"project-card\"><h3>GitHub Monitor</h3><p>Status: Running</p><button>Open</button></div></div><div class=\"logs-panel\"><h3>Logs</h3><p>[22:31] Monitor started...</p><p>[22:32] Change detected...</p></div></div></div></div>\n    <script type=\"module\" src=\"/src/main.jsx\"></script>\n  \n\n</body></html>",
